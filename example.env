# Copy this file to .env and fill in your values
# The bot reads from environment variables for security

# Required: Your Discord bot token
DISCORD_BOT_TOKEN=your_bot_token_here

# Optional: Channel ID where PC checks can be requested
# PC_CHECK_CHANNEL_ID=123456789

# Optional: Role IDs exempt from PC checks (comma-separated)
# TRUSTED_ROLE_IDS=123456789,987654321
